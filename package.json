{
  "name": "2connect-backend",
  "version": "1.0.0",
  "description": "2connect Backend API",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check .",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "test": "jest --config ./jest.config.cjs",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "migration:generate": "npm run build && npx sequelize-cli migration:generate --name",
    "migrate": "npm run build && npx sequelize-cli db:migrate",
    "migrate:revert": "npm run build && npx sequelize-cli db:migrate:undo",
    "migrate:create": "npx sequelize-cli migration:create --name",
    "migrate:run:all": "npx sequelize-cli db:migrate",
    "migrate:status": "npx sequelize-cli db:migrate:status",
    "migrate:undo:all": "npx sequelize-cli db:migrate:undo:all",
    "migrate:undo:specific": "npx sequelize-cli db:migrate:undo --name",
    "seed:generate": "npx sequelize-cli seed:generate --name",
    "seed": "npm run build && npx sequelize-cli db:seed:all",
    "seed:specific": "npx sequelize-cli db:seed --seed",
    "seed:undo": "npx sequelize-cli db:seed:undo",
    "seed:undo:all": "npx sequelize-cli db:seed:undo:all",
    "seed:undo:specific": "npx sequelize-cli db:seed:undo --seed",
    "db:init": "node scripts/init-db.js",
    "db:reset": "npx sequelize-cli db:migrate:undo:all && npm run migration:run",
    "db:setup": "npm run migration:run && npm run seed:run",
    "db:test-connection": "node scripts/debug-migration.js",
    "db:refresh": "npm run migration:undo:all && npm run migration:run && npm run seed:run",
    "db:reset:seed": "npm run migration:undo:all && npm run migration:run && npm run seed:run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.893.0",
    "@aws-sdk/client-sesv2": "^3.910.0",
    "@aws-sdk/credential-providers": "^3.899.0",
    "@nestjs-modules/ioredis": "^2.0.2",
    "@nestjs/axios": "^3.1.3",
    "@nestjs/bull": "^11.0.4",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/platform-socket.io": "^10.4.20",
    "@nestjs/schedule": "^6.0.1",
    "@nestjs/sequelize": "^10.0.1",
    "@nestjs/swagger": "^7.0.0",
    "@nestjs/terminus": "^10.0.0",
    "@nestjs/throttler": "^5.0.0",
    "@nestjs/websockets": "^10.4.20",
    "@sentry/node": "^10.40.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "axios": "^1.12.2",
    "bcrypt": "^5.0.0",
    "bull": "^4.16.5",
    "class-transformer": "^0.5.0",
    "class-validator": "^0.14.0",
    "cookie-parser": "^1.4.7",
    "crypto": "^1.0.1",
    "dayjs": "^1.11.18",
    "firebase-admin": "^13.5.0",
    "form-data": "^4.0.5",
    "google-auth-library": "^10.3.0",
    "ioredis": "^5.8.2",
    "jwks-rsa": "^4.0.1",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.9",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.16.3",
    "pg-hstore": "^2.3.4",
    "redis": "^4.7.1",
    "reflect-metadata": "^0.1.0",
    "rxjs": "^7.0.0",
    "sequelize": "^6.37.7",
    "sequelize-typescript": "^2.1.6",
    "socket.io": "^4.8.1",
    "stream-chat": "^9.26.0",
    "typescript-eslint": "^8.43.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/bcrypt": "^5.0.0",
    "@types/cookie-parser": "^1.4.9",
    "@types/express": "^4.17.23",
    "@types/jest": "^29.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.19.25",
    "@types/supertest": "^2.0.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^8.10.2",
    "eslint-plugin-prettier": "^4.2.5",
    "jest": "^29.0.0",
    "prettier": "^2.8.8",
    "sequelize-cli": "^6.0.0",
    "supertest": "^6.0.0",
    "ts-jest": "^29.0.0",
    "ts-loader": "^9.0.0",
    "ts-node": "^10.0.0",
    "tsconfig-paths": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
